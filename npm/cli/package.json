{
  "name": "@polycam/wgslpp",
  "version": "0.0.0",
  "description": "WGSL preprocessor, validator, reflector, and minifier — binary plus typed API",
  "homepage": "https://github.com/polycam/wgslpp",
  "repository": {
    "type": "git",
    "url": "https://github.com/polycam/wgslpp.git"
  },
